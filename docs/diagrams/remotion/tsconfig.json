{
  "compilerOptions": {
    "lib": ["dom", "esnext"],
    "module": "nodenext",
    "target": "esnext",
    "strict": true,
    "jsx": "react",
    "moduleResolution": "nodenext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
